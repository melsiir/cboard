<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Function key row -->
    <LinearLayout
        android:id="@+id/row_function"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        
        <Button
            android:id="@+id/key_escape"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ESC"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_tab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TAB"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_ctrl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CTRL"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_alt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ALT"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_shift"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SHIFT"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_space"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:text="SPACE"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_alt_gr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ALT GR"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_fn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FN"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_meta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="META"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_backspace"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BKSP"
            android:textSize="12sp"
            android:minHeight="48dp" />
    </LinearLayout>

    <!-- First symbol row -->
    <LinearLayout
        android:id="@+id/row_symbols_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        
        <Button
            android:id="@+id/key_brace_open"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="{"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_brace_close"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="}"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_bracket_open"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="["
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_bracket_close"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="]"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_paren_open"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="("
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_paren_close"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=")"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_angle_open"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="<"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_angle_close"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=">"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_equal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="="
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_exclamation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="!"
            android:textSize="16sp"
            android:minHeight="48dp" />
    </LinearLayout>

    <!-- Second symbol row -->
    <LinearLayout
        android:id="@+id/row_symbols_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        
        <Button
            android:id="@+id/key_ampersand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="&amp;"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_pipe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="|"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_star"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="*"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_slash"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="/"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_dash"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="-"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_plus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_percent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="%"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_caret"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="^"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_dollar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="$"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_hash"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="#"
            android:textSize="16sp"
            android:minHeight="48dp" />
    </LinearLayout>

    <!-- Third symbol row -->
    <LinearLayout
        android:id="@+id/row_symbols_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        
        <Button
            android:id="@+id/key_at"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_semicolon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=";"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_colon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=":"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_dot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="."
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_comma"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=","
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_underscore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="_"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_backslash"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="\\"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_tilde"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="~"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_tick"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="`"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_quote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="'"
            android:textSize="16sp"
            android:minHeight="48dp" />
    </LinearLayout>

    <!-- QWERTY row 1 -->
    <LinearLayout
        android:id="@+id/row_qwerty_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        
        <Button
            android:id="@+id/key_q"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="q"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_w"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="w"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_e"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="e"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_r"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="r"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_t"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="t"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_y"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="y"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_u"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="u"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_i"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="i"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_o"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="o"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_p"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="p"
            android:textSize="16sp"
            android:minHeight="48dp" />
    </LinearLayout>

    <!-- QWERTY row 2 -->
    <LinearLayout
        android:id="@+id/row_qwerty_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="0.5" />
            
        <Button
            android:id="@+id/key_a"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="a"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_s"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="s"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_d"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="d"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_f"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="f"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_g"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="g"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_h"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="h"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_j"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="j"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_k"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="k"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_l"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="l"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="0.5" />
    </LinearLayout>

    <!-- QWERTY row 3 -->
    <LinearLayout
        android:id="@+id/row_qwerty_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        
        <Button
            android:id="@+id/key_shift2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="SHIFT"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_z"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="z"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_x"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="x"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_c"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="c"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_v"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="v"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_b"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="b"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_n"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="n"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_m"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="m"
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_delete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="DEL"
            android:textSize="12sp"
            android:minHeight="48dp" />
    </LinearLayout>

    <!-- Bottom row -->
    <LinearLayout
        android:id="@+id/row_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        
        <Button
            android:id="@+id/key_symbol_switch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="?123"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_comma_bottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=","
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_space_bottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:text="SPACE"
            android:textSize="12sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_period"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="."
            android:textSize="16sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/key_return"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="RETURN"
            android:textSize="12sp"
            android:minHeight="48dp" />
    </LinearLayout>

</androidx.appcompat.widget.LinearLayoutCompat>